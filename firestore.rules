rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // USERS COLLECTION
    match /users/{userId} {
      // Anyone logged in can read checking for usernames
      allow read: if request.auth != null;
      // Only the account owner can create or update their own profile document
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // WORKOUTS COLLECTION
    match /workouts/{workoutId} {
      // Users can only read their own workouts (and friends in the future)
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid);
      // Users can only create workouts mapped to their own uid
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Users can only update or delete their own workouts
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
  }
}
